{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "subAgents": {
    "research": { "model": "claude-haiku-4-5-20251001", "maxTokens": 4096 },
    "test-runner": { "model": "claude-haiku-4-5-20251001", "maxTokens": 2048 },
    "changelog": { "model": "claude-haiku-4-5-20251001", "maxTokens": 2048 }
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git tag:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm test:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run preview:*)",
      "Bash(npm run init-db:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx playwright codegen:*)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir -p:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod +x:*)",
      "Bash(pm2 start:*)",
      "Bash(pm2 stop:*)",
      "Bash(pm2 restart:*)",
      "Bash(pm2 logs:*)",
      "Bash(pm2 status)",
      "Bash(pm2 save)",
      "Bash(openssl rand:*)",
      "Bash(sqlite3 *.db .schema)",
      "Bash(curl:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(gh auth login --with-token:*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(npm publish:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Read(.env)",
      "Read(backend/.env)",
      "Read(**/*.pem)",
      "Read(**/*credentials*.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/block-dangerous.sh" },
          { "type": "command", "command": ".claude/hooks/check-secrets.sh" }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/audit-log.sh" },
          { "type": "command", "command": ".claude/hooks/inject-memory.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/update-docs-check.sh" }
        ]
      }
    ]
  }
}

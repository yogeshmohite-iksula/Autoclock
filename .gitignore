# --- Secrets (NEVER commit) ---
.env
.env.local
.env.*.local
*.pem
*.key
*credentials*.json
serviceAccountKey*.json

# --- Dependencies ---
node_modules/
.pnpm-store/

# --- Build outputs ---
dist/
build/
.next/
out/
*.tsbuildinfo
# Vite writes the production SPA bundle here (see web/vite.config.js). It is
# generated by `npm install` → postinstall on every deploy; never committed.
backend/public/

# --- Databases & data ---
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
backups/

# --- Test / coverage ---
coverage/
test-results/
playwright-report/
playwright/.cache/
.nyc_output/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
logs/

# --- Editor / OS ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/

# --- Claude Code session-local ---
.claude/audit.jsonl
.claude/skill-feedback.json
.claude/cache/

# --- Misc ---
*.tmp
*.bak

# --- Build / runtime caches (per-machine, never in git) ---
node-compile-cache/
playwright-transform-cache-*/

# --- Large design-tool exports (kept locally, not in the repo) ---
# The bundled HTML prototypes can be 1.5–5.5 MB each. The small .md docs
# in docs/Project Docs/ stay tracked; only the bulky binary-ish exports
# under "docs/FrontEnd Design /" are excluded.
docs/FrontEnd Design /*.html
docs/FrontEnd Design /*.zip
docs/*.docx

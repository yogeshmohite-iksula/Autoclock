{
  "manifest_version": 3,
  "name": "AutoClock",
  "version": "0.1.0",
  "description": "Log your day once → posts Jira worklogs, appends your Google Sheet, drafts EOD email.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoClock — log a slot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": [
    "http://localhost:4000/*"
  ]
}

{
  "name": "autoclock-backend",
  "version": "0.1.0",
  "description": "AutoClock backend — Node + Express + SQLite (WAL). Self-hosted with PM2. Zero cost.",
  "private": true,
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "test": "node --test test/",
    "init-db": "node -e \"require('./db.js').init()\"",
    "pm2:start": "pm2 start server.js --name autoclock",
    "pm2:logs": "pm2 logs autoclock",
    "pm2:stop": "pm2 stop autoclock",
    "verify-db": "node scripts/verify-db.js",
    "reseed": "node scripts/reseed.js --yes"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {}
}

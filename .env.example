# =============================================================================
# AutoClock — Environment Variable Template
# Copy to backend/.env and fill in real values. NEVER commit a populated .env.
# Every variable below is referenced in DevDoc §3 / ERD §7. All keys are FREE.
# =============================================================================

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Sessions / Crypto (generate locally — zero cost) ---
# openssl rand -hex 32
SESSION_SECRET=
# openssl rand -hex 16   (32-byte AES-256 key for TB-06 token encryption — DevDoc §6.6)
TOKEN_ENC_KEY=

# --- Jira: demo user (HackFest M0) — classic API token, ADR-11 ---
JIRA_BASE_URL=https://iksula.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# Only set if the admin issues a SCOPED token instead of classic.
# Get from https://iksula.atlassian.net/_edge/tenant_info — DevDoc §6.1.
JIRA_CLOUD_ID=

# --- Jira: reader account (Ops member's broad Browse Projects token) — EP-23 / ERD §7.6 ---
JIRA_READER_EMAIL=
JIRA_READER_TOKEN=

# --- Google Workspace sign-in (OIDC) — ADR-10 / DevDoc §8.1 ---
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=http://localhost:4000/api/auth/login/callback

# --- Google API (Sheets + Gmail) — DevDoc §6.3 + §6.4 ---
# Project's OAuth consent screen MUST be set to "Internal" (Workspace org)
# to use gmail.compose restricted scope without verification — DevDoc §6.4.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# Captured before HackFest from a manual OAuth exchange (Work Plan P-4).
GOOGLE_DEMO_REFRESH_TOKEN=
# Gmail sender address for compliance reminder emails (FR-16 / notifier.js).
# IMPORTANT: the OAuth consent screen needs gmail.send scope for reminder emails
# (separate from the gmail.compose scope used for EOD drafts — DevDoc §6.4).
GOOGLE_DEMO_EMAIL=

# --- Atlassian OAuth 2.0 (3LO) — M1 pilot, per-user — DevDoc §6.5 ---
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:4000/api/auth/jira/callback

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:4000
